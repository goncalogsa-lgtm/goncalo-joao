            </nav>

            <div class="projects-collection-grid">

                <article class="collection-card" data-category="fullstack">

                    <div class="card-visual">
                        <img src="https://turbologo.com/articles/wp-content/uploads/2019/07/The-Trefoil-adidas-logo-1.jpg.webp"
