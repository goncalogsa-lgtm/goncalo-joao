<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio | Creative Technologist</title>
    <link rel="stylesheet" href="assets/css/estilo.min.css">
</head>

<body>

    <main>
        <!-- @import "header" -->
        <section class="hero-split">
            <div class="hero-texto animar-entrada">
                <span class="etiqueta">AVAILABLE FOR OPPORTUNITIES</span>
                <h1>UX/UI Designers &<br>Creative Minds</h1>
                <p>Crafting digital experiences with modern technologies. Specialized in building scalable applications
                    and elegant user interfaces.</p>

                <div class="botoes">
                    <a href="contacts.html" class="btn-branco">Get in Touch</a>
                    <a href="projects.html" class="btn-contorno">View Work</a>
                </div>
            </div>

            <div class="hero-stats animar-entrada atraso-1">
                <div class="cartao">
                    <h2>5+</h2>
                    <p>Years Experience</p>
                </div>
                <div class="cartao">
                    <h2>50+</h2>
                    <p>Projects Completed</p>
                </div>
                <div class="cartao">
                    <h2>15+</h2>
                    <p>Happy Clients</p>
                </div>
                <div class="cartao">
                    <h2>100K+</h2>
                    <p>Users Reached</p>
                </div>
            </div>
        </section>

        <section class="skills-section container">
            <div class="skills-header">
                <span class="etiqueta">EXPERTISE</span>
                <h2>Technical Skills</h2>
            </div>

            <div class="skills-grid">
                <div class="skill-category">
                    <h3>UX/UI </h3>
                    <div class="skill-tags">
                        <span>Design System</span>
                        <span>Service Design</span>
                        <span>Product Design</span>
                    </div>
                </div>

                <div class="skill-category">
                    <h3>Frontend Development</h3>
                    <div class="skill-tags">
                        <span>React</span>
                        <span>Vue.js</span>
                        <span>Angular</span>
                        <span>Svelte</span>
                    </div>
                </div>

                <div class="skill-category">
                    <h3>DevOps & Cloud </h3>
                    <div class="skill-tags">
                        <span>AWS</span>
                        <span>Docker</span>
                        <span>CI/CD</span>
                        <span>Kubernetes</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="projects-section container">
            <div class="section-header">
                <span class="etiqueta">SELECTED WORK</span>
                <h2>Featured Projects</h2>
            </div>

            <div class="projects-grid">
                <article class="project-card destaque">
                    <div class="project-top">
                        <span class="ano">2024</span>
                        <span class="seta">↗</span>
                    </div>
                    <h3>Celfocus Website</h3>
                    <p>Worked on a UX/UI design project at Celfocus focused on improving the usability and clarity of
                        enterprise digital solutions.</p>
                    <div class="skill-tags">
                        <span>React</span>
                        <span>Figma</span>

                    </div>
                </article>

                <article class="project-card">
                    <div class="project-top">
                        <span class="ano">2024 </span>
                        <span class="seta">↗</span>
                    </div>
                    <h3>Adidas Websites</h3>
                    <p>A Adidas website UX/UI concept designed to improve product discovery.</p>
                    <div class="skill-tags">
                        <span>Figma</span>
                        <span>React</span>
                    </div>
                </article>

                <article class="project-card">
                    <div class="project-top">
                        <span class="ano">2024</span>
                        <span class="seta">↗</span>
                    </div>
                    <h3>Vodafone</h3>
                    <p>A Vodafone design system project aimed at improving consistency and scalability across digital
                        interfaces.</p>
                    <div class="skill-tags">
                        <span>Figma</span>
                    </div>
                </article>
            </div>
        </section>

        <section class="experience-section container">
            <div class="section-header">
                <span class="etiqueta">CAREER</span>
                <h2>Experience</h2>
            </div>

            <div class="experience-list">

                <div class="experience-item">
                    <div class="exp-date">2024 - Now</div>
                    <div class="exp-details">
                        <h3>Mercedes UX/UI Designer</h3>
                        <span class="company">Car Company</span>
                        <p>Leading development of interfaces to improve flow.</p>
                    </div>
                </div>

                <div class="experience-item">
                    <div class="exp-date">2022 - 2024</div>
                    <div class="exp-details">
                        <h3>Nike Designer</h3>
                        <span class="company">Digital Agency</span>
                        <p>Built responsive interfaces for Nike</p>
                    </div>
                </div>

                <div class="experience-item">
                    <div class="exp-date">2020 - 2022</div>
                    <div class="exp-details">
                        <h3>Freelancers</h3>
                        <span class="company">Figma Designs</span>
                        <p>Contributed to several freelance works</p>
                    </div>
                </div>

                <div class="experience-item">
                    <div class="exp-date">2019 - 2020</div>
                    <div class="exp-details">
                        <h3>Siemens</h3>
                        <span class="company">Startup Inc</span>
                        <p>Contributed to product development and technical architecture</p>
                    </div>
                </div>

            </div>
        </section>

        <section class="contact-section container">
            <div class="contact-texto">
                <span class="etiqueta">GET IN TOUCH</span>
                <h2>Let's work<br>together</h2>
                <p>Open to new opportunities and interesting projects. Feel free to reach out for collaborations or just
                    a friendly chat.</p>
                <a href="mailto:your.email@example.com" class="email-link">your.email@example.com ↗</a>
            </div>

            <div class="contact-links">
                <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="caixa-link"
                    aria-label="Visit my GitHub profile">
                    <span>GitHub</span> <span class="seta">↗</span>
                </a>
                <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="caixa-link"
                    aria-label="Visit my LinkedIn profile">
                    <span>LinkedIn</span> <span class="seta">↗</span>
                </a>
                <a href="mailto:your.email@example.com" class="caixa-link" aria-label="Send me an email">
                    <span>Email</span> <span class="seta">↗</span>
                </a>
                <a href="#" class="caixa-link" aria-label="Download my Resume">
                    <span>Resume</span> <span class="seta">↗</span>
                </a>
            </div>
        </section>

    </main>

</body>

</html>