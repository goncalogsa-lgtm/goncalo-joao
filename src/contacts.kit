<!DOCTYPE html>
<html lang="pt-PT">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contactos | Nome do Grupo</title>
    <link rel="stylesheet" href="assets/css/estilo.min.css">
</head>

<body>
 <!-- @import "header" -->
    <main>
    <section class="contact-hero">
        <div class="contact-hero-texto">
            <span class="etiqueta">GET IN TOUCH</span>
            <h1>Let's Start a <em>Conversation</em></h1>
            <p>Have a project in mind or just want to chat? We are always open to discussing new opportunities, creative ideas, or potential collaborations.</p>
        </div>
    </section>
<section class="contact-form-section">
            <div class="contact-container">
                
                <div class="message-column">
                    <h3>Send a Message</h3>
                    <form action="#" class="main-form">
                        <div class="form-group">
                            <label for="name">Your Name</label>
                            <input type="text" id="name" placeholder="João Gonçalo" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" placeholder="joaoegoncalo@gmail.com" required>
                        </div>

                        <div class="form-group">
                            <label for="subject">Subject</label>
                            <select id="subject">
                                <option value="" disabled selected>Select a subject</option>
                                <option value="project">New Project</option>
                                <option value="collaboration">Collaboration</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea id="message" rows="5" placeholder="Tell us about your project..."></textarea>
                        </div>

                        <button type="submit" class="btn-submit">
                            Send Message <i class="fa-regular fa-paper-plane"></i>
                        </button>
                    </form>
                </div>

                <div class="info-column">
                    <div class="info-block">
                        <h3>Contact Information</h3>
                        <div class="info-item">
                            <i class="fa-regular fa-envelope"></i>
                            <div>
                                <span>Email</span>
                                <p>goncaloejoao@gmail.com</p>
                            </div>
                        </div>
                        <div class="info-item">
                            <i class="fa-solid fa-phone"></i>
                            <div>
                                <span>Phone</span>
                                <p>+351 956677201</p>
                            </div>
                        </div>
                        <div class="info-item">
                            <i class="fa-solid fa-location-dot"></i>
                            <div>
                                <span>Location</span>
                                <p>Lisboa, PT</p>
                            </div>
                        </div>
                    </div>

                    <div class="availability-block">
                        <h3>Availability</h3>

                        <div class="info-item">
                            <i class="fa-regular fa-clock"></i>
                            <div>
                                <span>Response Time</span>
                                <p>Within 24 hours</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="fa-regular fa-calendar-check"></i>
                            <div>
                                <span>Availability</span>
                                <p>Open to opportunities</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <i class="fa-regular fa-comments"></i>
                            <div>
                                <span>Preferred Contact</span>
                                <p>Email</p>
                            </div>
                        </div>
                    </div>

                    <div class="social-block">
                        <h3>Connect on Social</h3>
                        <div class="social-mini-grid">
                            <a href="https://github.com/goncalogsa-lgtm/goncalo-joao" class="social-mini-card">
                                <i class="fa-brands fa-github"></i>
                                <div>
                                    <span>GitHub</span>
                                    <p>@goncaloejoao</p>
                                </div>
                                <span class="mini-seta">↗</span>
                            </a>
                            <a href="https://www.linkedin.com/in/gon%C3%A7alo-almeida-439967225/" class="social-mini-card">
                                <i class="fa-brands fa-linkedin"></i>
                                <div>
                                    <span>LinkedIn</span>
                                    <p>Gonçalo&Joao</p>
                                </div>
                                <span class="mini-seta">↗</span>
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section class="faq-section">
            <div class="section-header">
                <span class="etiqueta">COMMON QUESTIONS</span>
                <h2>Frequently Asked</h2>
            </div>

            <div class="faq-list">
                
                <article class="faq-item">
                    <h3>What's your typical response time?</h3>
                    <p>We aim to respond to all inquiries within 24 hours during business days. For urgent matters, feel free to mention that in your message.</p>
                </article>

                <article class="faq-item">
                    <h3>Do you work on freelance projects?</h3>
                    <p>Yes! We are open to freelance opportunities that align with my expertise and schedule. Let's discuss your project requirements.</p>
                </article>

                <article class="faq-item">
                    <h3>What's your availability for new projects?</h3>
                    <p>We are currently available for select projects. Our schedule varies, so reach out and we can discuss timing and scope.</p>
                </article>

                <article class="faq-item">
                    <h3>Do you offer consultations?</h3>
                    <p>Absolutely! We offer initial consultations to discuss project requirements, technical approaches, and how I can help achieve your goals.</p>
                </article>

            </div>
        </section>

        <section class="cta-section">
            <div class="cta-container">
                <h2>Ready to Work Together?</h2>
                <p>Whether you have a detailed project plan or just an idea you'd like to explore, We'd love to hear from you. Let's create something amazing together.</p>
                
                <div class="botoes-cta">
                    <a href="mailto:your.email@example.com" class="btn-branco">Email Us Directly</a>
                    <a href="#" class="btn-contorno">Schedule a Call</a>
                </div>
            </div>
        </section>

</main>

    <!-- @import "footer" -->

</body>

</html>